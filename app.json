{
  "expo": {
    "name": "AI Study Coach",
    "slug": "ai-study-coach",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "aistudycoach",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.magnamic.aistudycoach"
    },
    "android": {
      "backgroundColor": "#0F172A",
      "package": "com.magnamic.aistudycoach"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
